# Optional overrides for local docker/podman/orbstack runs.

# llama-suite Web UI port on host
LLAMA_SUITE_WEBUI_PORT=8088

# External runtime endpoints (llama-swap)
LLAMA_SUITE_SWAP_API_URL=http://localhost:8080/v1
LLAMA_SUITE_SWAP_UI_URL=http://localhost:8080/ui

# Optional Open WebUI external URL (if you run it elsewhere)
LLAMA_SUITE_OPEN_WEBUI_URL=http://localhost:3000

# If you use the included open-webui container profile, host port:
OPEN_WEBUI_PORT=3000

